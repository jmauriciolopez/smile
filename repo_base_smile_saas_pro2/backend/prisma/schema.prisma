generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RolUsuario {
  administrador
  odontologo
  asistente
  ventas
}

enum EstadoPaciente {
  nuevo
  en_evaluacion
  con_diseno
  con_presupuesto
  en_seguimiento
  cerrado
  perdido
}

enum EstadoCaso {
  nuevo
  en_evaluacion
  con_fotos_cargadas
  con_diseno_borrador
  con_diseno_aprobado
  con_presupuesto_emitido
  en_negociacion
  cerrado
  pausado
}

enum EstadoPresupuesto {
  borrador
  listo_para_presentar
  presentado
  en_seguimiento
  en_negociacion
  aprobado
  rechazado
  vencido
}

model Usuario {
  id                  String     @id @default(uuid())
  nombre_completo     String
  email               String     @unique
  contrasena_hash     String
  rol                 RolUsuario
  activo              Boolean    @default(true)
  fecha_creacion      DateTime   @default(now())
  fecha_actualizacion DateTime   @updatedAt
  casos               CasoClinico[] @relation("UsuarioResponsableCasos")
}

model Paciente {
  id                       String            @id @default(uuid())
  nombre_completo          String
  telefono                 String?
  email                    String?
  ciudad                   String?
  observaciones_generales  String?
  estado_paciente          EstadoPaciente    @default(nuevo)
  fecha_creacion           DateTime          @default(now())
  fecha_actualizacion      DateTime          @updatedAt
  casos_clinicos           CasoClinico[]
  presupuestos             Presupuesto[]
}

model CasoClinico {
  id                      String      @id @default(uuid())
  paciente_id             String
  usuario_responsable_id  String?
  titulo                  String
  motivo_consulta         String?
  estado_caso             EstadoCaso  @default(nuevo)
  fecha_creacion          DateTime    @default(now())
  fecha_actualizacion     DateTime    @updatedAt
  paciente                Paciente    @relation(fields: [paciente_id], references: [id])
  usuario_responsable     Usuario?    @relation("UsuarioResponsableCasos", fields: [usuario_responsable_id], references: [id])
  presupuestos            Presupuesto[]
  disenos                 DisenoSonrisa[]
  fotos                   FotoClinica[]
  notas                   NotaClinica[]
}

model Presupuesto {
  id                    String             @id @default(uuid())
  paciente_id           String
  caso_clinico_id       String?
  estado_presupuesto    EstadoPresupuesto  @default(borrador)
  monto_total_estimado  Float
  cantidad_cuotas       Int                @default(1)
  fecha_creacion        DateTime           @default(now())
  fecha_actualizacion   DateTime           @updatedAt
  paciente              Paciente           @relation(fields: [paciente_id], references: [id])
  caso_clinico          CasoClinico?       @relation(fields: [caso_clinico_id], references: [id])
  opciones              OpcionTratamiento[]
  seguimientos          SeguimientoComercial[]
}

model OpcionTratamiento {
  id               String       @id @default(uuid())
  presupuesto_id   String
  titulo           String
  descripcion      String?
  monto            Float
  recomendada      Boolean      @default(false)
  presupuesto      Presupuesto  @relation(fields: [presupuesto_id], references: [id])
}

model SeguimientoComercial {
  id               String       @id @default(uuid())
  presupuesto_id   String
  comentario       String
  proxima_accion   String?
  fecha_accion     DateTime?
  fecha_creacion   DateTime     @default(now())
  presupuesto      Presupuesto  @relation(fields: [presupuesto_id], references: [id])
}

model NotaClinica {
  id               String       @id @default(uuid())
  caso_clinico_id  String
  contenido        String
  fecha_creacion   DateTime     @default(now())
  caso_clinico     CasoClinico  @relation(fields: [caso_clinico_id], references: [id])
}

model TareaInterna {
  id               String       @id @default(uuid())
  titulo           String
  descripcion      String?
  completada       Boolean      @default(false)
  fecha_vencimiento DateTime?
  fecha_creacion   DateTime     @default(now())
}

model DisenoSonrisa {
  id                    String      @id @default(uuid())
  caso_clinico_id       String
  ajustes_json          String      // Guardamos posiciones, escala, etc.
  score_json            String?     // Historial de scores de IA y sugerencias
  url_imagen_resultado  String?
  activo                Boolean     @default(true)
  fecha_creacion        DateTime    @default(now())
  fecha_actualizacion   DateTime    @updatedAt
  caso_clinico          CasoClinico @relation(fields: [caso_clinico_id], references: [id])
}

model SignatureDesign {
  id                    String      @id @default(uuid())
  caso_clinico_id       String      @unique
  url_scan_stl          String?
  url_waxup_stl         String?
  url_retrato_jpg       String?
  alineacion_json       String?     // Matrix de transformación 3D
  puntos_labio_json     String?     // Puntos de la curva Bezier
  fecha_creacion        DateTime    @default(now())
  fecha_actualizacion   DateTime    @updatedAt
  caso_clinico          CasoClinico @relation(fields: [caso_clinico_id], references: [id])
}

model CBCTStudy {
  id                    String      @id @default(uuid())
  caso_clinico_id       String
  nombre_estudio        String
  url_zip_dicom         String?
  metadatos_json        String?     // Windowing, slices, modalidad
  fecha_creacion        DateTime    @default(now())
  caso_clinico          CasoClinico @relation(fields: [caso_clinico_id], references: [id])
}

model FotoClinica {
  id               String      @id @default(uuid())
  caso_clinico_id  String
  url_foto         String
  tipo             String      // frontal, lateral, etc
  fecha_creacion   DateTime    @default(now())
  caso_clinico     CasoClinico @relation(fields: [caso_clinico_id], references: [id])
}

model AuditLog {
  id               String   @id @default(uuid())
  tipo_accion      String   // LOGIN_EXITOSO, ACCESO_PACIENTE, etc.
  usuario_id       String?
  entidad_tipo     String?  // 'paciente', 'caso', 'diseno', etc.
  entidad_id       String?
  descripcion      String
  ip_origen        String?
  metadata         String?  // JSON string
  fecha_creacion   DateTime @default(now())

  @@index([usuario_id])
  @@index([entidad_id])
  @@index([fecha_creacion])
}

model PlantillaSonrisa {
  id              String   @id
  nombre          String
  categoria       String
  parametros      Json     // Almacena proporciones, forma, color, etc.
  fecha_creacion  DateTime @default(now())
}
